    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "oauth4webapi": "^3.8.6",
    "typescript": "^6.0.3",
    "vite": "npm:@voidzero-dev/vite-plus-core@0.1.24",
    "vite-plugin-pwa": "^1.3.0",
    "vite-plus": "0.1.24"
  },
  "overrides": {
    "serialize-javascript": ">=6.0.3",
