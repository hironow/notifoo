{
  "name": "notifoo",
  "version": "0.0.1",
  "description": "A starter kit for building PWAs!",
  "license": "ISC",
  "author": "",
  "main": "index.js",
  "scripts": {
    "dev-server": "vp dev --open",
    "dev": "npm run dev-server",
    "dev-task": "vp dev",
    "deploy": "bash scripts/deploy.sh",
    "build": "tsc && vp build",
    "start": "npm run dev",
    "start-remote": "vp dev --host",
    "prepare": "vp config",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@awesome.me/webawesome": "^3.5.0",
    "@thepassle/app-tools": "^1.2.0",
    "lit": "^3.3.2",
    "urlpattern-polyfill": "^10.1.0",
    "workbox-build": "^7.4.0",
    "workbox-core": "^7.4.0",
    "workbox-precaching": "^7.4.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/node": "^25.6.0",
    "typescript": "^6.0.2",
    "vite": "npm:@voidzero-dev/vite-plus-core@latest",
    "vite-plugin-pwa": "^1.2.0",
    "vite-plus": "latest"
  },
  "packageManager": "pnpm@10.33.0",
  "pnpm": {
    "overrides": {
      "vite": "npm:@voidzero-dev/vite-plus-core@latest",
      "vitest": "npm:@voidzero-dev/vite-plus-test@latest"
    }
  }
}
